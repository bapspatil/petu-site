---
interface Props {
  class?: string;
  color?: string;
}
const { class: className = "", color = "#ffe066" } = Astro.props;
---
<svg
  class={className}
  viewBox="0 0 40 40"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <path
    d="M 20 2 Q 22 18 38 20 Q 22 22 20 38 Q 18 22 2 20 Q 18 18 20 2 Z"
    fill={color}
  />
  <circle cx="20" cy="20" r="2.5" fill="#fffaf6" opacity="0.85" />
</svg>
