---
import Heart from "./svg/Heart.astro";
import Sparkle from "./svg/Sparkle.astro";

const navLinks = [
  { href: "#crisis", label: "Audit" },
  { href: "#why", label: "Forecast" },
  { href: "#get-involved", label: "Protocol" },
  { href: "#founder", label: "Founder" },
  { href: "#partnership", label: "PETE" },
];
---

<!-- Desktop / always-visible pill -->
<nav
  id="petu-nav"
  class="fixed inset-x-0 top-3 md:top-4 z-40 px-3 md:px-4 pointer-events-none"
  aria-label="Primary"
>
  <div
    class="petu-nav-pill pointer-events-auto max-w-[720px] mx-auto bg-petu-cream/90 backdrop-blur-md border-2 border-petu-pink-200 rounded-full shadow-kawaii px-3 md:px-4 py-2 flex items-center justify-between gap-2"
  >
    <!-- Logo -->
    <a
      href="#hero"
      class="petu-nav-logo flex items-center gap-2 group shrink-0 px-1.5 py-0.5 rounded-full"
      aria-label="PETU home"
    >
      <span class="petu-nav-logo-mark inline-block w-8 h-8 transition-transform duration-300 group-hover:rotate-[-10deg] group-hover:scale-110">
        <img src="/favicon.svg" alt="" class="w-full h-full" />
      </span>
      <span class="font-display font-bold text-lg md:text-xl text-petu-ink">PETU</span>
    </a>

    <!-- Desktop nav links -->
    <ul class="hidden md:flex items-center gap-0.5 lg:gap-1">
      {navLinks.map((link) => (
        <li class="petu-nav-item">
          <a
            href={link.href}
            class="inline-block px-2.5 lg:px-3 py-1.5 rounded-full text-sm font-semibold text-petu-ink hover:bg-petu-pink-100 hover:text-petu-pink-600 hover:scale-105 transition-all"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Desktop CTA -->
    <a
      href="#get-involved"
      class="petu-nav-cta hidden md:inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-petu-pink-500 hover:bg-petu-pink-600 text-white font-semibold text-sm shadow-sm transition-all hover:-translate-y-0.5 shrink-0 group"
    >
      Pledge
      <span class="inline-block transition-transform duration-300 group-hover:scale-125 group-hover:rotate-12">
        <Heart class="w-3.5" color="#fffaf6" />
      </span>
    </a>

    <!-- Mobile menu toggle -->
    <button
      id="petu-nav-toggle"
      type="button"
      class="petu-nav-toggle md:hidden w-9 h-9 rounded-full bg-petu-pink-100 hover:bg-petu-pink-200 text-petu-ink flex items-center justify-center transition-colors shrink-0"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="petu-nav-mobile"
    >
      <svg class="petu-nav-icon-open w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" aria-hidden="true">
        <path d="M4 7h16M4 12h16M4 17h16" />
      </svg>
    </button>
  </div>
</nav>

<!-- Mobile full-screen menu overlay -->
<div
  id="petu-nav-mobile"
  class="hidden md:hidden fixed inset-0 z-50 bg-gradient-to-br from-petu-pink-50 via-petu-cream to-petu-blue-100 flex flex-col"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
>
  <!-- decorative sparkles -->
  <Sparkle class="absolute top-24 left-[14%] w-7 opacity-70" color="#ffd23f" />
  <Sparkle class="absolute top-40 right-[18%] w-6 opacity-65" color="#ffb6d5" />
  <Sparkle class="absolute bottom-44 left-[20%] w-8 opacity-60" color="#a8d4ff" />
  <Sparkle class="absolute bottom-28 right-[14%] w-5 opacity-65" color="#ffe066" />

  <!-- Header -->
  <div class="flex items-center justify-between px-5 py-4 border-b-2 border-petu-pink-200/60">
    <div class="flex items-center gap-2">
      <img src="/favicon.svg" alt="" class="w-9 h-9" />
      <span class="font-display font-bold text-xl text-petu-ink">PETU</span>
    </div>
    <button
      id="petu-nav-close"
      type="button"
      class="w-10 h-10 rounded-full bg-petu-pink-100 hover:bg-petu-pink-200 text-petu-ink flex items-center justify-center transition-colors"
      aria-label="Close navigation menu"
    >
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" aria-hidden="true">
        <path d="M6 6l12 12M18 6L6 18" />
      </svg>
    </button>
  </div>

  <!-- Links centered, large + bouncy -->
  <ul class="flex-1 flex flex-col justify-center items-center gap-2 px-6 relative z-10">
    {navLinks.map((link) => (
      <li class="petu-nav-mobile-item w-full text-center">
        <a
          href={link.href}
          class="inline-block py-3 px-6 rounded-full font-display font-bold text-3xl text-petu-ink hover:text-petu-pink-600 hover:scale-105 transition-all"
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>

  <!-- Footer CTA -->
  <div class="petu-nav-mobile-cta px-6 pb-8 pt-4 relative z-10">
    <a
      href="#get-involved"
      class="flex items-center justify-center gap-2 w-full px-6 py-4 rounded-full bg-petu-pink-500 hover:bg-petu-pink-600 text-white font-semibold text-lg shadow-kawaii transition-all"
    >
      Take the Pledge
      <Heart class="w-5" color="#fffaf6" />
    </a>
  </div>
</div>
