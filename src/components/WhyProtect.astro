---
import Sparkle from "./svg/Sparkle.astro";
import Cloud from "./svg/Cloud.astro";

const projections = [
  {
    year: "2031",
    label: "Surface Saturation",
    accent: "petu-pink",
    body: "Every printable surface in the developed world is occupied. Glassware, ceiling fans, the inside of refrigerator doors. Designers must invent new surfaces purely to absorb demand.",
  },
  {
    year: "2034",
    label: "The Optional Horn",
    accent: "petu-blue",
    body: "Mass production discovers it can sell more units without the horn. A hornless unicorn enters circulation. The mythology degrades, very quietly, in the back of a Target.",
  },
  {
    year: "2040",
    label: "Recognition Collapse",
    accent: "petu-yellow",
    body: "A child, shown a unicorn outside the context of a t-shirt, fails to identify it. The image and the meaning have detached. We will not be able to put them back together.",
  },
];

const accentMap: Record<string, { ring: string; chip: string; year: string }> = {
  "petu-pink": {
    ring: "border-petu-pink-200",
    chip: "bg-petu-pink-100 text-petu-pink-600",
    year: "text-petu-pink-500",
  },
  "petu-blue": {
    ring: "border-petu-blue-200",
    chip: "bg-petu-blue-100 text-petu-blue-500",
    year: "text-petu-blue-500",
  },
  "petu-yellow": {
    ring: "border-petu-yellow-200",
    chip: "bg-petu-yellow-200 text-petu-ink",
    year: "text-petu-yellow-400",
  },
};
---

<section id="why" class="relative py-24 md:py-32 px-6 md:px-10 bg-gradient-to-b from-petu-blue-100 via-petu-pink-50 to-petu-cream overflow-hidden">
  <Cloud class="absolute top-12 right-[8%] w-32 md:w-40 opacity-70 petu-float-slow" color="#ffe1ec" />
  <Sparkle class="absolute top-16 left-[12%] w-7 opacity-70" color="#ffe066" />
  <Sparkle class="absolute bottom-24 right-[14%] w-6 opacity-70" color="#ffb6d5" />

  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16 petu-reveal">
      <span class="inline-block px-4 py-1.5 mb-4 rounded-full bg-petu-blue-200 text-petu-blue-500 text-base font-semibold">
        Forecast · Internal
      </span>
      <h2 class="font-display font-bold text-4xl md:text-6xl text-petu-ink mb-4">
        If We Do Not <span class="text-petu-pink-500">Stop.</span>
      </h2>
      <p class="text-base text-petu-ink-soft max-w-2xl mx-auto leading-relaxed">
        Three near-future scenarios our research department has refused to dismiss.
        Read them with the calm that comes from already knowing.
      </p>
    </div>

    <div class="relative grid md:grid-cols-3 gap-6 md:gap-8 petu-stagger">
      <div class="absolute hidden md:block left-0 right-0 top-1/2 h-0.5 bg-gradient-to-r from-petu-pink-200 via-petu-blue-200 to-petu-yellow-200 -z-0" aria-hidden="true"></div>

      {projections.map((p) => {
        const a = accentMap[p.accent];
        return (
          <div class={`petu-card relative bg-white rounded-[var(--radius-blob-lg)] p-7 md:p-8 border-2 ${a.ring} shadow-kawaii hover:-translate-y-1 transition-transform z-10`}>
            <div class={`inline-block px-3 py-1 rounded-full text-base font-semibold ${a.chip} mb-4`}>
              Year {p.year}
            </div>
            <div class={`font-display font-bold text-5xl md:text-6xl ${a.year} mb-2 leading-none`}>
              {p.year}
            </div>
            <h3 class="font-display font-bold text-xl text-petu-ink mb-3">
              {p.label}
            </h3>
            <p class="text-base text-petu-ink-soft leading-relaxed">
              {p.body}
            </p>
          </div>
        );
      })}
    </div>

    <p class="petu-reveal text-center mt-12 text-base text-petu-ink-soft italic max-w-xl mx-auto">
      All projections sourced from PETU's internal Saturation Modelling Group.
      We are happy to share methodology with anyone who asks twice.
    </p>
  </div>
</section>
