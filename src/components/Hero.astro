---
import UnicornMascot from "./svg/UnicornMascot.astro";
import Sparkle from "./svg/Sparkle.astro";
import Cloud from "./svg/Cloud.astro";
import Star from "./svg/Star.astro";
import Heart from "./svg/Heart.astro";
---

<section
  id="hero"
  class="relative overflow-hidden bg-gradient-to-b from-petu-pink-50 via-petu-pink-100 to-petu-blue-100 pt-24 md:pt-0 md:min-h-screen md:flex md:items-center"
>
  <Cloud class="absolute top-12 left-[6%] w-32 md:w-40 opacity-80 petu-float-slow" />
  <Cloud class="absolute top-28 right-[8%] w-40 md:w-52 opacity-90 petu-float-slow" color="#ffe1ec" />
  <Cloud class="absolute bottom-32 left-[12%] w-24 md:w-32 opacity-70 petu-float-slow" color="#fff5b8" />

  <Sparkle class="petu-sparkle absolute top-[18%] left-[18%] w-6 md:w-8" />
  <Sparkle class="petu-sparkle absolute top-[30%] right-[22%] w-5 md:w-7" color="#ffb6d5" />
  <Sparkle class="petu-sparkle absolute top-[60%] left-[8%] w-4 md:w-6" color="#a8d4ff" />
  <Sparkle class="petu-sparkle absolute top-[70%] right-[14%] w-7 md:w-9" />
  <Sparkle class="petu-sparkle absolute top-[42%] right-[8%] w-5 md:w-6" color="#ffe066" />
  <Star class="petu-sparkle absolute bottom-[18%] left-[24%] w-5 md:w-7" color="#ff95c2" />
  <Heart class="petu-sparkle absolute top-[50%] left-[14%] w-5 md:w-7" />

  <div class="relative z-10 max-w-6xl mx-auto px-6 md:px-10 grid md:grid-cols-2 gap-8 md:gap-12 items-center py-8 md:py-0">
    <div class="text-center md:text-left order-2 md:order-1">
      <span class="petu-hero-badge inline-block px-4 py-1.5 mb-5 rounded-full bg-petu-yellow-200 text-petu-ink text-base font-semibold shadow-kawaii">
        Est. Norway, 1824
      </span>
      <h1 class="font-display text-5xl md:text-7xl font-bold text-petu-ink leading-[1.05] mb-3">
        Defending
        <br />
        the <span class="text-petu-pink-500">unicorn.</span>
      </h1>
      <p class="petu-hero-subhead font-display text-lg md:text-xl font-bold text-petu-pink-600 mb-4 max-w-md mx-auto md:mx-0 leading-snug">
        People for the Ethical Treatment of Unicorns.
      </p>
      <p class="petu-hero-body text-base text-petu-ink-soft mb-8 max-w-md mx-auto md:mx-0 leading-relaxed">
        She has opinions; she did not consent to the lunchboxes; she certainly did not consent to the
        mugs. <strong class="text-petu-pink-600">PETU</strong> is an independent society defending
        her image, her meaning, and the slowly vanishing dignity of the horn.
      </p>
      <div class="flex flex-wrap gap-3 justify-center md:justify-start">
        <a
          href="#get-involved"
          class="petu-hero-cta inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-petu-pink-500 hover:bg-petu-pink-600 text-white font-semibold shadow-kawaii transition-all hover:-translate-y-0.5"
        >
          Take the Pledge
          <span aria-hidden="true">→</span>
        </a>
        <a
          href="#crisis"
          class="petu-hero-cta inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-white/80 hover:bg-white text-petu-blue-500 font-semibold border-2 border-petu-blue-300 shadow-kawaii-blue transition-all hover:-translate-y-0.5"
        >
          View the Audit
        </a>
      </div>
    </div>

    <div class="relative flex justify-center order-1 md:order-2">
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="w-56 h-56 sm:w-64 sm:h-64 md:w-96 md:h-96 rounded-full bg-petu-yellow-100 blur-3xl opacity-70"></div>
      </div>
      <div id="hero-mascot" class="relative w-52 sm:w-60 md:w-80 lg:w-96">
        <UnicornMascot class="w-full h-auto drop-shadow-xl" />
      </div>
    </div>
  </div>

  <div class="relative md:absolute md:bottom-0 left-0 right-0 bg-white/60 backdrop-blur-sm border-t-2 border-petu-pink-200 py-4 md:py-5 z-10">
    <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 sm:grid-cols-3 gap-4 md:gap-8 text-center">
      <div class="petu-hero-stat">
        <div class="font-display font-bold text-2xl md:text-3xl text-petu-pink-500" data-counter data-target="1400000000" data-suffix="+">0</div>
        <div class="text-base text-petu-ink-soft mt-1 leading-tight">unicorn impressions printed daily</div>
      </div>
      <div class="petu-hero-stat sm:border-x-2 sm:border-petu-pink-100 sm:px-2">
        <div class="font-display font-bold text-2xl md:text-3xl text-petu-blue-500">$0.00</div>
        <div class="text-base text-petu-ink-soft mt-1 leading-tight">paid in royalties since 1824</div>
      </div>
      <div class="petu-hero-stat">
        <div class="font-display font-bold text-2xl md:text-3xl text-petu-yellow-400" data-counter data-target="47">0</div>
        <div class="text-base text-petu-ink-soft mt-1 leading-tight">avg. unicorns per child's bedroom</div>
      </div>
    </div>
  </div>
</section>
