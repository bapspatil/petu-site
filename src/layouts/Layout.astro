---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "PETU: People for Ethical Treatment of Unicorns",
  description = "An independent society advocating for the dignity, image rights, and iconographic restraint owed to unicorns. Founded Norway, 1824. In partnership with PETE.",
  image = "/og-image.svg",
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://petu.info";
const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://petu.info").toString();
const ogImage = new URL(image, Astro.site ?? "https://petu.info").toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta name="theme-color" content="#ffb6d5" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#3a2a3f" media="(prefers-color-scheme: dark)" />
    <meta name="color-scheme" content="light" />
    <meta name="format-detection" content="telephone=no" />

    <meta name="author" content="PETU (People for Ethical Treatment of Unicorns)" />
    <meta name="publisher" content="PETU" />
    <meta name="keywords" content="PETU, unicorns, satire, kawaii, non-profit, parody, Norway, 1824, PETE, partnership, iconography, image rights" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" sizes="any" />
    <link rel="alternate icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="mask-icon" href="/favicon.svg" color="#ff7eb8" />
    <link rel="shortcut icon" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="PETU" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/svg+xml" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="PETU: People for Ethical Treatment of Unicorns. The unicorn is not a pattern. Norway, 1824." />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="PETU: People for Ethical Treatment of Unicorns. The unicorn is not a pattern. Norway, 1824." />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700&family=Quicksand:wght@400;500;600;700&display=swap"
    />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "NGO",
      name: "PETU",
      alternateName: "People for Ethical Treatment of Unicorns",
      description,
      url: siteUrl,
      logo: new URL("/favicon.svg", Astro.site ?? "https://petu.info").toString(),
      image: ogImage,
      foundingDate: "1824",
      foundingLocation: {
        "@type": "Place",
        name: "Norway",
      },
      founder: {
        "@type": "Person",
        name: "David Gumpel",
      },
      sameAs: ["https://thisispete.org"],
    })} />
  </head>
  <body>
    <slot />
  </body>
</html>
